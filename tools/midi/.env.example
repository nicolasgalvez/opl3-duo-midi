# Copy to .env and set your path. Base path to your MIDI library.
# Relative `opl serve` / `opl play` paths resolve against this when not found in the cwd,
# e.g.  opl serve "_Bobby Prince" -r   ->   $MIDI_LIBRARY/_Bobby Prince
MIDI_LIBRARY=/path/to/video-game-music-90000-midi-files

# Default audio input device for `opl render` (RtAudio/CoreAudio device name, substring match).
# Run `opl render --list-audio` to see devices and their input channel counts.
OPL_AUDIO_DEVICE=Clarett 4Pre

# Optional: capture just one stereo pair from a multi-channel interface (1-based).
# e.g. the OPL3's audio arrives on Clarett inputs 5/6.
OPL_AUDIO_CHANNELS=5,6

# Optional: audio sample rate (default 48000; match your interface).
OPL_AUDIO_RATE=48000

# Default MIDI output device for `opl render` (substring match).
# Leave unset to auto-detect (prefers "OPL3Duo", falls back to first port).
OPL_MIDI_DEVICE=Clarett 4Pre MIDI

# Web/visualizer theme: "green" (default CRT phosphor) or "winamp" (metallic LCD).
OPL_THEME=green

# App title shown in the web player and the rendered video (brand it your own).
OPL_TITLE=OPL · MIDI PLAYER
