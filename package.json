{
  "name": "opl3-duo-midi-tooling",
  "version": "0.0.0",
  "private": true,
  "description": "Repo-wide dev tooling (format + lint pre-commit hooks) for the OPL3 Duo MIDI project. The firmware is C++ (PlatformIO); the companion CLI is in tools/midi.",
  "type": "module",
  "workspaces": [
    "tools/midi"
  ],
  "bin": {
    "opl": "./tools/midi/opl.mjs"
  },
  "scripts": {
    "prepare": "husky",
    "format": "npm run format:cpp && npm run format:js",
    "format:cpp": "git ls-files '*.c' '*.cc' '*.cpp' '*.cxx' '*.h' '*.hpp' '*.ino' | xargs clang-format -i",
    "format:js": "prettier --write \"tools/midi/**/*.{js,mjs}\"",
    "lint": "eslint tools/midi",
    "test": "npm run test --workspace=tools/midi",
    "test:unit": "npm run test:unit --workspace=tools/midi",
    "typecheck": "npm run typecheck --workspace=tools/midi"
  },
  "lint-staged": {
    "*.{c,cc,cpp,cxx,h,hpp,ino}": "clang-format -i",
    "tools/midi/**/*.{js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.3"
  }
}
